{
  "name": "strnd",
  "version": "0.1.0",
  "description": "Codebase intelligence for AI agents — stop exploring, start building",
  "repository": {
    "type": "git",
    "url": "https://github.com/joellopezjl96/strnd"
  },
  "type": "module",
  "bin": {
    "strnd": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx",
    "scan": "tsx src/cli/scan.ts",
    "encode": "tsx src/encoder/encode.ts",
    "batch": "tsx src/cli/index.ts batch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/",
    "!dist/**/__tests__/",
    "!dist/batch/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "codebase",
    "llm",
    "developer-tools",
    "claude",
    "claude-code",
    "context-window",
    "static-analysis",
    "blast-radius"
  ],
  "author": "Joel Lopez Berrum",
  "license": "MIT",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
