{
  "name": "strand",
  "version": "0.1.0",
  "description": "Codebase intelligence for AI agents — stop exploring, start building",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "strand": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx",
    "scan": "tsx src/cli/scan.ts",
    "encode": "tsx src/encoder/encode.ts",
    "batch": "tsx src/cli/index.ts batch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "codebase",
    "visual-encoding",
    "llm",
    "developer-tools",
    "claude",
    "claude-code",
    "context-window"
  ],
  "author": "Joel Lopez Berrum",
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/node": "^25.3.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
